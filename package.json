{
  "name": "lb4-llm-chat-component",
  "version": "2.1.1",
  "description": "Package to integrate LLM based capabilities into any loopback4 application",
  "keywords": [
    "loopback-extension",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=10.16"
  },
  "exports": {
    ".": "./dist/index.js",
    "./aws": {
      "type": "./dist/sub-modules/providers/aws/index.d.ts",
      "default": "./dist/sub-modules/providers/aws/index.js"
    },
    "./google": {
      "type": "./dist/sub-modules/providers/google/index.d.ts",
      "default": "./dist/sub-modules/providers/google/index.js"
    },
    "./anthropic": {
      "type": "./dist/sub-modules/providers/anthropic/index.d.ts",
      "default": "./dist/sub-modules/providers/anthropic/index.js"
    },
    "./ollama": {
      "type": "./dist/sub-modules/providers/ollama/index.d.ts",
      "default": "./dist/sub-modules/providers/ollama/index.js"
    },
    "./cerebras": {
      "type": "./dist/sub-modules/providers/cerebras/index.d.ts",
      "default": "./dist/sub-modules/providers/cerebras/index.js"
    },
    "./openai": {
      "type": "./dist/sub-modules/providers/openai/index.d.ts",
      "default": "./dist/sub-modules/providers/openai/index.js"
    },
    "./groq": {
      "type": "./dist/sub-modules/providers/groq/index.d.ts",
      "default": "./dist/sub-modules/providers/groq/index.js"
    },
    "./openrouter": {
      "type": "./dist/sub-modules/providers/openrouter/index.d.ts",
      "default": "./dist/sub-modules/providers/openrouter/index.js"
    },
    "./pg": {
      "type": "./dist/sub-modules/providers/pg/index.d.ts",
      "default": "./dist/sub-modules/providers/pg/index.js"
    },
    "./db-query/testing": {
      "type": "./dist/components/db-query/testing/index.d.ts",
      "default": "./dist/components/db-query/testing/index.js"
    },
    "./langfuse": {
      "type": "./dist/sub-modules/obf/langfuse/index.d.ts",
      "default": "./dist/sub-modules/obf/langfuse/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "aws": [
        "dist/sub-modules/providers/aws/index.d.ts"
      ],
      "google": [
        "dist/sub-modules/providers/google/index.d.ts"
      ],
      "anthropic": [
        "dist/sub-modules/providers/anthropic/index.d.ts"
      ],
      "ollama": [
        "dist/sub-modules/providers/ollama/index.d.ts"
      ],
      "cerebras": [
        "dist/sub-modules/providers/cerebras/index.d.ts"
      ],
      "openai": [
        "dist/sub-modules/providers/openai/index.d.ts"
      ],
      "groq": [
        "dist/sub-modules/providers/groq/index.d.ts"
      ],
      "openrouter": [
        "dist/sub-modules/providers/openrouter/index.d.ts"
      ],
      "pg": [
        "dist/sub-modules/providers/pg/index.d.ts"
      ],
      "db-query/testing": [
        "dist/components/db-query/testing/index.d.ts"
      ],
      "langfuse": [
        "dist/sub-modules/obf/langfuse/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "npm run eslint && npm run prettier:check",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "pretest": "npm run rebuild",
    "test": "lb-mocha --timeout=500000 --allow-console-logs \"dist/__tests__\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --timeout=500000 --allow-console-logs dist/__tests__/**/*.js && npm run posttest",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "rebuild": "npm run clean && npm run build",
    "prune": "npm prune --production",
    "coverage": "nyc npm run test",
    "migrate:pg:up": "db-migrate up --config migrations/pg/database.json --migrations-dir migrations/pg/migrations",
    "migrate:pg:down": "db-migrate down --config migrations/pg/database.json --migrations-dir migrations/pg/migrations",
    "prepare": "test \"$HUSKY\" = \"0\" || husky install",
    "build:diagram": "ts-node scripts/visualize-graph"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sourcefuse/loopback4-llm-chat-extension.git"
  },
  "author": "",
  "license": "MIT",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "peerDependencies": {
    "@loopback/core": "^7.0.11"
  },
  "dependencies": {
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@loopback/context": "^8.0.11",
    "@loopback/repository": "^8.0.11",
    "@loopback/sequelize": "^0.8.8",
    "@sourceloop/chat-service": "^17.0.6",
    "@sourceloop/core": "^20.0.6",
    "@sourceloop/file-utils": "^0.5.6",
    "langchain": "^1.3.3",
    "loopback4-authentication": "^13.0.4",
    "loopback4-authorization": "^8.1.5",
    "prom-client": "^15.1.3",
    "tslib": "^2.8.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@google/generative-ai": "^0.24.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/aws": "^1.3.5",
    "@langchain/cerebras": "^1.0.4",
    "@langchain/google-genai": "^2.1.27",
    "@langchain/groq": "^1.2.0",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.4",
    "@langchain/openrouter": "^0.2.2",
    "@langfuse/core": "^5.1.0",
    "@langfuse/langchain": "^5.1.0",
    "@loopback/build": "^12.0.11",
    "@loopback/eslint-config": "^16.0.1",
    "@loopback/testlab": "^8.0.11",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/dotenv": "^8.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.16.14",
    "commitizen": "^4.3.1",
    "cz-format-extension": "^1.6.0",
    "db-migrate": "^1.0.0-beta.35",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "husky": "^7.0.4",
    "jsonwebtoken": "^9.0.3",
    "loopback-connector-sqlite3": "^3.0.0",
    "mochawesome": "^7.1.4",
    "pg": "^8.20.0",
    "semantic-release": "^25.0.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "glob": "11.1.0",
    "jws": "3.2.3",
    "node-forge": "1.4.0",
    "validator": "13.15.22",
    "axios": "1.15.0",
    "fast-xml-parser": "5.5.8",
    "simple-git": "3.33.0",
    "flatted": "3.4.2",
    "serialize-javascript": "7.0.4",
    "multer": "2.1.1",
    "sequelize": "6.37.8",
    "underscore": "1.13.8",
    "tar": "7.5.12",
    "minimatch": "10.2.4",
    "undici": "6.24.1",
    "ignore": "7.0.5",
    "@sourceloop/file-utils": {
      "@loopback/context": "8.0.11"
    },
    "swagger-stats": {
      "send": "^1.1.0"
    },
    "loopback-connector-rest": {
      "jsonpath-plus": "^10.2.0"
    },
    "loopback-connector-sqlite3": {
      "sqlite3": "5.1.7"
    },
    "commitizen": {
      "inquirer": "^12.9.6"
    }
  },
  "config": {
    "commitizen": {
      "path": "cz-format-extension"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "release": {
    "branches": [
      "main",
      "beta",
      "alpha"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "angular",
          "releaseRules": [
            {
              "type": "chore",
              "scope": "deps",
              "release": "patch"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": true,
          "pkgRoot": ".",
          "tarballDir": "dist",
          "npmPublishSkipScripts": true
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} semantic"
        }
      ],
      "@semantic-release/github"
    ],
    "repositoryUrl": "https://github.com/sourcefuse/loopback4-llm-chat-extension.git"
  }
}
